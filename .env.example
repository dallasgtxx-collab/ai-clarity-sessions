# Stripe test or live secret key. Never expose this value in the browser.
STRIPE_SECRET_KEY=

# Server-side Stripe Price IDs.
STRIPE_BEGINNER_PRICE_ID=
STRIPE_WORKSHOP_PRICE_ID=
STRIPE_BOOTCAMP_PRICE_ID=
STRIPE_MEMBERSHIP_PRICE_ID=

# Created after the public webhook endpoint is added in Stripe.
STRIPE_WEBHOOK_SECRET=

# Local: http://localhost:3000
# Production: https://aiclaritysessions.com
SITE_URL=http://localhost:3000

# Keep false until Stripe activation, policies, support email, and the public
# webhook are confirmed. Local development can still use Stripe test mode.
ENABLE_LIVE_CHECKOUT=false

# Activate this mailbox before turning on live checkout.
NEXT_PUBLIC_SUPPORT_EMAIL=hello@aiclaritysessions.com
