# Stripe test or live secret key. Never expose this value in the browser.
STRIPE_SECRET_KEY=

# Server-side Stripe Price IDs.
STRIPE_BEGINNER_PRICE_ID=
STRIPE_WORKSHOP_PRICE_ID=
STRIPE_BOOTCAMP_PRICE_ID=
STRIPE_MEMBERSHIP_PRICE_ID=

# Created after the public webhook endpoint is added in Stripe.
STRIPE_WEBHOOK_SECRET=

# Local: http://localhost:3000
# Production: https://aiclaritysessions.com
SITE_URL=http://localhost:3000

# Keep false until Stripe activation, policies, support email, and the public
# webhook are confirmed. Local development can still use Stripe test mode.
ENABLE_LIVE_CHECKOUT=false

# Activate this mailbox before turning on live checkout.
NEXT_PUBLIC_SUPPORT_EMAIL=hello@aiclaritysessions.com

# Supabase project URL and browser-safe anonymous key. RLS restricts access.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server only. Never prefix this value with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Resend transactional email. Server only.
RESEND_API_KEY=
EMAIL_FROM=AI Clarity Sessions <classes@aiclaritysessions.com>
EMAIL_REPLY_TO=hello@aiclaritysessions.com
ADMIN_NOTIFICATION_EMAIL=

# Long random secret used by Vercel Cron. Server only.
CRON_SECRET=

# Optional, consent-gated analytics. Leave blank to disable each provider.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_CLARITY_PROJECT_ID=
